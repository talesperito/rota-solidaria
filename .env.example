# Rota Solidária — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores do Supabase.
# Nunca versione o arquivo .env.local

# URL do seu projeto Supabase
# Encontre em: https://app.supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave anônima (pública) do Supabase
# Encontre em: https://app.supabase.com → seu projeto → Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_aqui
